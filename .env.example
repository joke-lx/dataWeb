# Copy to `.env` and adjust as needed. Consumed by docker-compose*.yml.
# NEVER commit a real .env (it is gitignored).

# Image tag used by docker-compose.prod.yml (latest | <git-sha>).
TAG=latest

# Backend data root inside the api container. Point at an empty/missing dir to
# force deterministic mock data; mount real omics data to ./data for real reads.
DATAWEB_DATA_ROOT=/data
